{
    "name": "AF BFC Scan",
    "filter": {
        "tag": "AF_DEBUG",
        "keyword": "CheckDebugMode"
    },
    "patterns": [
        {
            "type": "segment",
            "params": {
                "delimiter": "|",
                "strip": true,
                "inner_type": "key_value",
                "separator": " ",
                "keys": ["Dof", "FirstPos", "step", "point", "CurrLens", "pdResult", "aiResult", "pdAvg", "aiAvg"]
            }
        }
    ],
    "visualization": {
        "layout": "grid",
        "plots": [
            {"title": "Lens Position", "keys": ["CurrLens"], "y_label": "DAC"},
            {"title": "PD Result",     "keys": ["pdResult", "pdAvg"], "y_label": "Defocus"},
            {"title": "AI Result",     "keys": ["aiResult", "aiAvg"], "y_label": "Defocus"}
        ]
    }
}
